{
  "name": "ZombieWaves",
  "tree": {
    "$className": "DataModel",

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/server"
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$properties": {
        "CameraMode": "LockFirstPerson",
        "CharacterWalkSpeed": 17.6
      },
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src/client"
      }
    },

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$path": "src/shared"
      },
      "Events": {
        "$className": "Folder",
        "RequestBuyWallWeapon": { "$className": "RemoteEvent" },
        "RequestBuyDoor": { "$className": "RemoteEvent" },
        "RequestBuyShopItem": { "$className": "RemoteEvent" },
        "RequestSelectClass": { "$className": "RemoteEvent" },
        "RequestVoteHardcore": { "$className": "RemoteEvent" },
        "UpdateMoney": { "$className": "RemoteEvent" },
        "UpdateWave": { "$className": "RemoteEvent" },
        "UpdateHealth": { "$className": "RemoteEvent" },
        "UpdateAmmo": { "$className": "RemoteEvent" },
        "ShowNotification": { "$className": "RemoteEvent" },
        "WaveCompleted": { "$className": "RemoteEvent" },
        "BossSpawned": { "$className": "RemoteEvent" },
        "BossHealthUpdate": { "$className": "RemoteEvent" },
        "GameOver": { "$className": "RemoteEvent" },
        "ClassSelected": { "$className": "RemoteEvent" },
        "BonusActivated": { "$className": "RemoteEvent" },
        "ZombieDied": { "$className": "RemoteEvent" },
        "PlayerDied": { "$className": "RemoteEvent" },
        "DoorOpened": { "$className": "RemoteEvent" },
        "GameStarted": { "$className": "RemoteEvent" }
      }
    },

    "StarterGui": {
      "$className": "StarterGui",
      "$ignoreUnknownInstances": true
    },

    "Workspace": {
      "$className": "Workspace",
      "$ignoreUnknownInstances": true,
      "SpawnPoints": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "ZombieSpawns": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "WallBuys": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "Doors": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "Zones": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      }
    },

    "ServerStorage": {
      "$className": "ServerStorage",
      "$ignoreUnknownInstances": true,
      "ZombieTemplates": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "WeaponTemplates": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      }
    },

    "SoundService": {
      "$className": "SoundService",
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
