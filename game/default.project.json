{
  "name": "ZombieWaves",
  "tree": {
    "$className": "DataModel",
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/server",
      "$ignoreUnknownInstances": true
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$properties": {
        "CharacterWalkSpeed": 17.6
      },
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src/client",
        "$ignoreUnknownInstances": true
      }
    },
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$path": "src/shared"
      },
      "Weapons": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "Events": {
        "$className": "Folder",
        "RequestBuyWallWeapon": {
          "$className": "RemoteEvent"
        },
        "RequestBuyDoor": {
          "$className": "RemoteEvent"
        },
        "RequestBuyShopItem": {
          "$className": "RemoteEvent"
        },
        "RequestSelectClass": {
          "$className": "RemoteEvent"
        },
        "RequestVoteHardcore": {
          "$className": "RemoteEvent"
        },
        "UpdateMoney": {
          "$className": "RemoteEvent"
        },
        "UpdateWave": {
          "$className": "RemoteEvent"
        },
        "UpdateHealth": {
          "$className": "RemoteEvent"
        },
        "ShowNotification": {
          "$className": "RemoteEvent"
        },
        "WaveCompleted": {
          "$className": "RemoteEvent"
        },
        "BossSpawned": {
          "$className": "RemoteEvent"
        },
        "BossHealthUpdate": {
          "$className": "RemoteEvent"
        },
        "GameOver": {
          "$className": "RemoteEvent"
        },
        "ClassSelected": {
          "$className": "RemoteEvent"
        },
        "BonusActivated": {
          "$className": "RemoteEvent"
        },
        "ZombieDied": {
          "$className": "RemoteEvent"
        },
        "PlayerDied": {
          "$className": "RemoteEvent"
        },
        "DoorOpened": {
          "$className": "RemoteEvent"
        },
        "GameStarted": {
          "$className": "RemoteEvent"
        },
        "DamageZombie": {
          "$className": "RemoteEvent"
        },
        "gunEvent": {
          "$className": "BindableEvent"
        },
        "viewmodelEvent": {
          "$className": "BindableEvent"
        },
        "gunFunction": {
          "$className": "BindableFunction"
        },
        "viewmodelFunction": {
          "$className": "BindableFunction"
        }
      }
    },
    "StarterGui": {
      "$className": "StarterGui",
      "$ignoreUnknownInstances": true
    },
    "Workspace": {
      "$className": "Workspace",
      "$ignoreUnknownInstances": true,
      "SpawnPoints": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "ZombieSpawns": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "WallBuys": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "Doors": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "Zones": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      }
    },
    "ServerStorage": {
      "$className": "ServerStorage",
      "$ignoreUnknownInstances": true,
      "ZombieTemplates": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      },
      "WeaponTemplates": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      }
    },
    "SoundService": {
      "$className": "SoundService",
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
